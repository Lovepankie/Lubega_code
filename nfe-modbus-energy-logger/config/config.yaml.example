port: /dev/ttyUSB0

modbus:
  backend: pymodbus     # Options: pymodbus, mbpoll

# Addressing scheme:
# - Single-phase meters: 10-99 (room for 90 meters)
# - Three-phase meters: 100+ (high addresses to avoid conflicts)

meters:
  - id: 100
    name: "main_three_phase"
    type: "3phase"
    enabled: true

  - id: 10
    name: "single_phase_1"
    type: "1phase"
    enabled: false

  - id: 11
    name: "single_phase_2"
    type: "1phase"
    enabled: false

# Separate polling and logging intervals
poll_interval: 10       # Poll every 10 seconds (accurate energy calc)
log_interval: 900       # Log every 15 minutes

# Logging configuration
logging:
  base_dir: data
  state_dir: data/state

  # Log rotation settings
  rotation:
    max_rows: 50000     # ~17 months at 15-min intervals
    compress_old: true  # Gzip old files to save space
